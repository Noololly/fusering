---
import Button from "../../reusable/button.astro";
const { text, tip } = Astro.props;
---

<div
  class="h-fit md:h-[45vh] flex flex-col items-center justify-center ml-[2rem] mr-[2rem]"
>
  <h1 class="font-phantom_sans font-bold text-3xl text-cadillac-50 mb-[2rem]">
    {text}
  </h1>
  <div class="flex flex-col lg:flex-row">
    <Button text="Home" link="/" />
    <Button
      text="Fusion Guide"
      link="https://www.figma.com/deck/YKlZnPUlueoqIcxXVRMAAx/Fusering-Guide?node-id=1-42&t=wM0EW9K0Sto00QEE-1"
    />
    <Button
      text="Onshape Guide"
      link="https://www.figma.com/deck/gX6MAxP5ipzvqXmF9K3tIt/Fusering-Workshop---Onshape-Edition?node-id=1-82&viewport=-148%2C-157%2C0.72&t=vqxwmheaOU7zs9fd-1&scaling=min-zoom&content-scaling=fixed&page-id=0%3A1"
    />
    <Button
      text="Run a workshop"
      link="https://forms.hackclub.com/fusering-workshop"
    />
  </div>
  <h1 class="font-phantom_sans text-2xl text-cadillac-100 mb-[2rem]">
    {tip}
  </h1>
</div>
