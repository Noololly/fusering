---
import Button from "../../reusable/button.astro";

// Import images
const gallerypreview1 = "/images/GalleryPreview1.webp";
const gallerypreview2 = "/images/GalleryPreview2.webp";
const gallerypreview3 = "/images/GalleryPreview3.webp";
const gallerypreview4 = "/images/GalleryPreview4.webp";
const gallerypreview5 = "/images/GalleryPreview5.webp";
const gallerypreview6 = "/images/GalleryPreview6.webp";
const gallerypreview7 = "/images/GalleryPreview7.webp";
const gallerypreview8 = "/images/GalleryPreview8.webp";
---

<div class="hidden flex-col relative items-start justify-center lg:flex">
  <div class="flex flex-row items-center h-[30vh] w-fit ml-[8rem]">
    <h1 class="font-phantom_sans font-bold text-4xl text-cadillac-50">
      See designs made by fellow Hack Clubbers!
    </h1>
    <Button link="/gallery" text="Gallery" />
  </div>
  <div class="relative w-screen h-[90vh] overflow-hidden">
    <!-- make the inner grid wider/taller than the viewport and translate it left so tiles are clipped at the page edges *vibecoded* -->
    <div
      class="grid grid-cols-6 grid-rows-2 gap-6 w-[140vw] h-[80vh] min-h-fit -translate-x-20 rotate-3 origin-left"
      style="transform-origin: left;"
    >
      <div class="col-span-2 rounded-2xl shadow-md">
        <img
          src={gallerypreview4}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-span-2 col-start-3 rounded-2xl shadow-md">
        <img
          src={gallerypreview5}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-span-2 col-start-5 rounded-2xl shadow-md">
        <img
          src={gallerypreview2}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-span-2 col-start-2 row-start-2 rounded-2xl shadow-md">
        <img
          src={gallerypreview3}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-span-2 col-start-4 row-start-2 rounded-2xl shadow-md">
        <img
          src={gallerypreview8}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-start-6 row-start-2 rounded-2xl shadow-md">
        <img
          src={gallerypreview1}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
      <div class="col-start-1 row-start-2 rounded-2xl shadow-md">
        <img
          src={gallerypreview6}
          class="w-full h-full overflow-hidden rounded-2xl object-cover"
        />
      </div>
    </div>
  </div>
</div>
