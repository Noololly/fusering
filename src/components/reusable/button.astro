---
const { text } = Astro.props;
const { link } = Astro.props;
---

<a
  class="w-fit min-w-[80vw] lg:min-w-3xs text-center h-fit bg-cadillac-500 lg:m-[2rem] m-[1rem] pl-[2rem] pr-[2rem] pt-[0.5rem] pb-[0.5rem] rounded-4xl bottom-[15rem] text-cadillac-50 font-phantom_sans text-xl font-bold border-3 border-cadillac-300 shadow-lg hover:shadow-2xl"
  href={link}>{text}</a
>
